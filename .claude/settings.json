{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "if": "Bash(git commit*)",
            "command": "jq -r '.tool_input.command' | grep -q 'git commit' && npx prettier . --write 2>/dev/null || true",
            "statusMessage": "Running prettier before commit..."
          }
        ]
      }
    ]
  }
}
